[Desktop Entry]
Type=Application
Icon=tools-wizard-symbolic
Name=DefenestraOS Bootloader Restoring Tool
Comment=Restore the bootloader if it has been overwritten by Windows
Keywords=bootloader;fix;grub;windows
Categories=System;Utility
Exec=/usr/bin/bootloader_restore
Hidden=false
NoDisplay=false
StartupNotify=true
Terminal=false
